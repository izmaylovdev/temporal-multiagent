# ---- LLM (host-side agents) ----
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---- Temporal ----
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=agent-sandbox

# ---- Agent loop ----
MAX_ITERATIONS=4
WORKFLOW_TIMEOUT_SECONDS=600

# ---- Sandbox ----
# auto = use runsc (gVisor) if available, else fall back to runc
SANDBOX_RUNTIME=auto
SANDBOX_IMAGE=agent-sandbox:latest
SANDBOX_MEMORY=512m
SANDBOX_CPUS=1.0
SANDBOX_PIDS=128
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_OUTPUT_MAX_BYTES=131072

# ---- Uploads ----
MAX_FILE_BYTES=10485760
MAX_TOTAL_UPLOAD_BYTES=26214400

# ---- Run storage ----
# RUNS_DIR is the path inside the api/worker containers.
# RUNS_DIR_HOST is the SAME directory on the Docker host, used when launching
# sandbox child containers (docker-out-of-docker bind mounts use host paths).
RUNS_DIR=/data/runs
RUNS_DIR_HOST=./.runs

# ---- Langfuse (self-hosted, see docker-compose) ----
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
