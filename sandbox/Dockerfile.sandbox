# Minimal sandbox image for untrusted, model-generated Python.
# No shell tooling beyond what Python needs; numpy/pandas (+ excel/parquet readers) preinstalled.
# All isolation (no network, read-only rootfs, dropped caps, non-root, resource caps) is applied
# at `docker run` time by app/sandbox.py — see that file and the README.
FROM python:3.11-slim

RUN pip install --no-cache-dir \
        numpy==2.1.3 \
        pandas==2.2.3 \
        openpyxl==3.1.5 \
        pyarrow==18.1.0 \
    && find /usr/local -name '__pycache__' -type d -prune -exec rm -rf '{}' +

# Non-root by default (docker run also pins --user 65534:65534).
USER 65534:65534
WORKDIR /work
CMD ["python", "/work/script.py"]
